local Window = OrionLib:MakeWindow({
	Name = "Example By Altis",
	HidePremium = false,
	SaveConfig = false,
	ConfigFolder = "Example",
	IntroEnabled = true,
	IntroText = "Altis",
	Theme = "Dark"
})

----------------------------------------------------------------
-- MOD SECTION
----------------------------------------------------------------

getgenv().BackgroundImage = true
getgenv().ToggleUi = true
getgenv().ResizeCorner = true

local function OrionMod()
	local CoreGui = game:GetService("CoreGui")
	local UIS = game:GetService("UserInputService")
	local Players = game:GetService("Players")

	local Player = Players.LocalPlayer
	local PlayerGui = Player:WaitForChild("PlayerGui")

	local BackGroundImage = "rbxassetid://121863942764840"
	local ToggleUiImage = "rbxassetid://115202978995434"

	local ToggleUiSize = UDim2.new(0, 45, 0, 45)
	local ToggleUiPosition = UDim2.new(0, 20, 0.5, -22)

	local ToggleUiCorner = 10
	local MainUiCorner = 10

	local function IsOrionGui(obj)
		return obj:IsA("ScreenGui") and string.find(obj.Name, "Orion", 1, true) ~= nil
	end

	local function FindOrionGui()
		for _, gui in ipairs(CoreGui:GetDescendants()) do
			if IsOrionGui(gui) then
				return gui
			end
		end
		return nil
	end

	local function FindMainFrame(OrionGui)
		local Main
		local BestArea = 0

		for _, v in ipairs(OrionGui:GetDescendants()) do
			if v:IsA("Frame") then
				local sx, sy = v.Size.X.Offset, v.Size.Y.Offset
				if sx > 500 and sy > 200 then
					local Area = sx * sy
					if Area > BestArea then
						BestArea = Area
						Main = v
					end
				end
			end
		end

		return Main
	end

	local function StyleObject(obj, BG)
		if obj:IsA("Frame") then
			obj.BackgroundTransparency = 1
			obj.BorderSizePixel = 0
		elseif obj:IsA("ScrollingFrame") then
			obj.BackgroundTransparency = 1
			obj.BorderSizePixel = 0
			obj.ScrollBarImageTransparency = 1
		elseif obj:IsA("TextButton") then
			obj.BackgroundTransparency = 1
			obj.BorderSizePixel = 0
		elseif obj:IsA("TextBox") then
			obj.BackgroundTransparency = 1
			obj.BorderSizePixel = 0
		elseif obj:IsA("ImageButton") then
			obj.BackgroundTransparency = 1
			obj.BorderSizePixel = 0
		elseif obj:IsA("ImageLabel") and obj ~= BG then
			obj.BackgroundTransparency = 1
		end

		if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
			obj.TextColor3 = Color3.fromRGB(255, 255, 255)
			obj.TextStrokeTransparency = 0.7
		end

		if obj:IsA("GuiObject") and obj ~= BG then
			obj.ZIndex = obj.ZIndex + 10
		end
	end

	local function ApplyToMain(Main, OrionGui)
		if not Main or Main:GetAttribute("AltisModApplied") then
			return
		end

		Main:SetAttribute("AltisModApplied", true)

		local BG

		------------------------------------------------------------
		-- BACKGROUND
		------------------------------------------------------------

		if getgenv().BackgroundImage then
			Main.BackgroundTransparency = 1

			BG = Main:FindFirstChild("AltisBackground")
			if not BG then
				BG = Instance.new("ImageLabel")
				BG.Name = "AltisBackground"
				BG.Parent = Main
			end

			BG.Size = UDim2.new(1, 0, 1, 0)
			BG.Position = UDim2.new(0, 0, 0, 0)
			BG.BackgroundTransparency = 1
			BG.Image = BackGroundImage
			BG.ImageTransparency = 0.2
			BG.ScaleType = Enum.ScaleType.Stretch
			BG.ZIndex = 0

			local Corner = BG:FindFirstChildOfClass("UICorner") or Instance.new("UICorner")
			Corner.CornerRadius = UDim.new(0, MainUiCorner)
			Corner.Parent = BG

			for _, v in ipairs(Main:GetDescendants()) do
				StyleObject(v, BG)
			end

			Main.DescendantAdded:Connect(function(obj)
				if obj and obj.Parent then
					StyleObject(obj, BG)
				end
			end)

			Main:GetPropertyChangedSignal("Visible"):Connect(function()
				if BG then
					BG.Visible = Main.Visible
				end
			end)
		else
			for _, v in ipairs(Main:GetDescendants()) do
				StyleObject(v, nil)
			end

			Main.DescendantAdded:Connect(function(obj)
				if obj and obj.Parent then
					StyleObject(obj, nil)
				end
			end)
		end

------------------------------------------------------------
-- RESIZE CORNER
------------------------------------------------------------

if getgenv().ResizeCorner then
	if not Main:FindFirstChild("AltisResizeCorner") then
		local ResizeButton = Instance.new("TextButton")
		ResizeButton.Name = "AltisResizeCorner"
		ResizeButton.Parent = Main
		ResizeButton.AnchorPoint = Vector2.new(1, 1)
		ResizeButton.Position = UDim2.new(1, -6, 1, -6)
		ResizeButton.Size = UDim2.new(0, 20, 0, 20)
		ResizeButton.BackgroundTransparency = 1
		ResizeButton.BorderSizePixel = 0
		ResizeButton.Text = ""
		ResizeButton.TextTransparency = 1
		ResizeButton.AutoButtonColor = false
		ResizeButton.ZIndex = 999999

		local ResizeImage = Instance.new("ImageLabel")
		ResizeImage.Name = "ResizeIcon"
		ResizeImage.Parent = ResizeButton
		ResizeImage.BackgroundTransparency = 1
		ResizeImage.BorderSizePixel = 0
		ResizeImage.Size = UDim2.fromScale(1, 1)
		ResizeImage.Position = UDim2.new(0, 0, 0, 0)
		ResizeImage.Image = "rbxassetid://130573561415972"
		ResizeImage.ImageTransparency = 0.15
		ResizeImage.ZIndex = ResizeButton.ZIndex + 1

		local ResizeCornerObject = Instance.new("UICorner")
		ResizeCornerObject.CornerRadius = UDim.new(0, 6)
		ResizeCornerObject.Parent = ResizeButton

		local Resizing = false
		local ResizeStart
		local StartSize

		ResizeButton.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1
				or input.UserInputType == Enum.UserInputType.Touch then
				Resizing = true
				ResizeStart = input.Position
				StartSize = Main.Size

				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then
						Resizing = false
					end
				end)
			end
		end)

		UIS.InputChanged:Connect(function(input)
			if Resizing and (
				input.UserInputType == Enum.UserInputType.MouseMovement
				or input.UserInputType == Enum.UserInputType.Touch
			) then
				local Delta = input.Position - ResizeStart

				Main.Size = UDim2.new(
					StartSize.X.Scale,
					math.clamp(StartSize.X.Offset + Delta.X, 500, 1200),
					StartSize.Y.Scale,
					math.clamp(StartSize.Y.Offset + Delta.Y, 300, 900)
				)
			end
		end)
	end
end

		------------------------------------------------------------
		-- TOGGLE UI
		------------------------------------------------------------

		if getgenv().ToggleUi then
			local OldToggle = PlayerGui:FindFirstChild("AltisToggle")

                        if OldToggle then
	                        OldToggle:Destroy()
                        end

local ToggleGui = Instance.new("ScreenGui")
ToggleGui.Name = "AltisToggle"
ToggleGui.ResetOnSpawn = false
ToggleGui.IgnoreGuiInset = true
ToggleGui.Parent = PlayerGui

			local Toggle = ToggleGui:FindFirstChild("AltisToggleButton")
			if not Toggle then
				Toggle = Instance.new("ImageButton")
				Toggle.Name = "AltisToggleButton"
				Toggle.Parent = ToggleGui
				Toggle.Size = ToggleUiSize
				Toggle.Position = ToggleUiPosition
				Toggle.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
				Toggle.BackgroundTransparency = 0
				Toggle.BorderSizePixel = 0
				Toggle.Image = ToggleUiImage
				Toggle.AutoButtonColor = true
				Toggle.ZIndex = 999999

				local ToggleCornerObject = Instance.new("UICorner")
				ToggleCornerObject.CornerRadius = UDim.new(0, ToggleUiCorner)
				ToggleCornerObject.Parent = Toggle

				local ToggleStroke = Instance.new("UIStroke")
				ToggleStroke.Parent = Toggle
				ToggleStroke.Color = Color3.fromRGB(255, 255, 255)
				ToggleStroke.Transparency = 0.7
				ToggleStroke.Thickness = 1.2

				local Dragging = false
				local DragInput
				local DragStart
				local StartPos

				local function UpdateDrag(input)
					local Delta = input.Position - DragStart
					Toggle.Position = UDim2.new(
						StartPos.X.Scale,
						StartPos.X.Offset + Delta.X,
						StartPos.Y.Scale,
						StartPos.Y.Offset + Delta.Y
					)
				end

				Toggle.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1
						or input.UserInputType == Enum.UserInputType.Touch then
						Dragging = true
						DragStart = input.Position
						StartPos = Toggle.Position
					end
				end)

				Toggle.InputChanged:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseMovement
						or input.UserInputType == Enum.UserInputType.Touch then
						DragInput = input
					end
				end)



				Toggle.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1
						or input.UserInputType == Enum.UserInputType.Touch then
						Dragging = false
					end
				end)

				UIS.InputChanged:Connect(function(input)
					if Dragging and input == DragInput then
						UpdateDrag(input)
					end
				end)

				local UiOpened = true

				local function GetMainFrame()
					local CurrentOrionGui = OrionGui or FindOrionGui()
					if not CurrentOrionGui then
						return nil
					end
					return FindMainFrame(CurrentOrionGui)
				end

				Toggle.MouseButton1Click:Connect(function()
					local MainFrame = GetMainFrame()
					if MainFrame then
						UiOpened = not UiOpened
						MainFrame.Visible = UiOpened
					end
				end)
			end
		end
	end

	task.spawn(function()
		repeat task.wait() until CoreGui:FindFirstChildWhichIsA("ScreenGui")

		local OrionGui = FindOrionGui()
		while not OrionGui do
			task.wait(0.2)
			OrionGui = FindOrionGui()
		end

		local Main = FindMainFrame(OrionGui)
		while not Main do
			task.wait(0.2)
			Main = FindMainFrame(OrionGui)
		end

		ApplyToMain(Main, OrionGui)

		OrionGui.DescendantAdded:Connect(function(obj)
			if not obj then
				return
			end

			if obj:IsA("Frame") and obj.Size.X.Offset > 500 and obj.Size.Y.Offset > 200 then
				task.defer(function()
					local NewMain = FindMainFrame(OrionGui)
					if NewMain then
						ApplyToMain(NewMain, OrionGui)
					end
				end)
			end
		end)
	end)
end

OrionMod()
